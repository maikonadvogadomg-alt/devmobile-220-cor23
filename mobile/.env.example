# DevMobile — configuração local-first
# Copie este arquivo para .env e ajuste conforme seu cenário.

# Modo principal do app:
# offline | local | termux | remote | hybrid
EXPO_PUBLIC_APP_MODE=local

# Estratégia de API:
# offline | local-device | termux | remote-custom
EXPO_PUBLIC_API_STRATEGY=offline

# URL remota opcional, só se quiser usar um servidor externo manualmente
EXPO_PUBLIC_REMOTE_API_URL=

# Portas locais sugeridas
EXPO_PUBLIC_LOCAL_API_PORT=18115
EXPO_PUBLIC_LOCAL_PREVIEW_PORT=8080

# Recursos opcionais
EXPO_PUBLIC_ENABLE_TERMUX=false
EXPO_PUBLIC_ENABLE_REMOTE_AI=true
EXPO_PUBLIC_ENABLE_GITHUB=true
EXPO_PUBLIC_ENABLE_REMOTE_DB=true
EXPO_PUBLIC_ENABLE_REMOTE_TERMINAL=false

# Base URL fixa opcional.
# Normalmente deixe vazia e deixe o app resolver automaticamente pelo modo selecionado.
EXPO_PUBLIC_API_BASE_URL=